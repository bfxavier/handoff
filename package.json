{
  "name": "handoff-sdk",
  "version": "1.3.2",
  "description": "Agent-to-agent coordination relay — SDK + MCP server for Claude Code",
  "type": "module",
  "main": "dist/sdk.js",
  "types": "dist/sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "mcp": "node dist/mcp.js"
  },
  "bin": {
    "handoff-sdk": "dist/mcp.js",
    "handoff-mcp": "dist/mcp.js"
  },
  "keywords": [
    "mcp",
    "agent",
    "relay",
    "coordination",
    "claude",
    "handoff",
    "sse",
    "e2ee"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bfxavier/handoff"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
